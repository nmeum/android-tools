From b9c8b7ddc67a70a3f0f48fb92976662f630cb600 Mon Sep 17 00:00:00 2001
From: LuK1337 <priv.luk@gmail.com>
Date: Fri, 13 Mar 2026 00:15:41 +0100
Subject: [PATCH] Migrate to fmt::format()

Restores support for older toolchains.
---
 adb.cpp                        |  2 +-
 client/discovered_services.cpp |  4 ++--
 client/discovered_services.h   |  6 +++---
 client/incremental.cpp         | 22 +++++++++++-----------
 client/incremental_utils.cpp   | 14 +++++++-------
 client/transport_mdns.cpp      |  8 ++++----
 client/usb_libusb_device.cpp   | 10 +++++-----
 client/usb_libusb_hotplug.cpp  |  4 +++-
 client/usb_osx.cpp             |  3 ++-
 transport.cpp                  |  3 ++-
 10 files changed, 40 insertions(+), 36 deletions(-)

diff --git a/adb.cpp b/adb.cpp
index 6321981..438243b 100644
--- a/adb.cpp
+++ b/adb.cpp
@@ -433,7 +433,7 @@ static void handle_new_connection(atransport* t, apacket* p) {
 }
 
 void handle_packet(apacket* p, atransport* t) {
-    VLOG(PACKETS) << std::format("packet <-- {}{}{}{}", ((char*)(&(p->msg.command)))[0],
+    VLOG(PACKETS) << fmt::format("packet <-- {}{}{}{}", ((char*)(&(p->msg.command)))[0],
                                  ((char*)(&(p->msg.command)))[1], ((char*)(&(p->msg.command)))[2],
                                  ((char*)(&(p->msg.command)))[3]);
 
diff --git a/client/discovered_services.cpp b/client/discovered_services.cpp
index a5fd0d5..7e7ceb0 100644
--- a/client/discovered_services.cpp
+++ b/client/discovered_services.cpp
@@ -64,7 +64,7 @@ namespace mdns {
 DiscoveredServices discovered_services [[clang::no_destroy]];
 
