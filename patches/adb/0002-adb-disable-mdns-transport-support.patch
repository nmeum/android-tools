From: =?UTF-8?q?S=C3=B6ren=20Tempel?= <soeren+git@soeren-tempel.net>
Date: Sun, 1 Sep 2019 15:04:18 +0000
Subject: [PATCH] adb: disable mdns transport support

Would require patching the MDNS code as well.
---
 client/main.cpp | 4 ----
 1 file changed, 4 deletions(-)

diff --git a/client/main.cpp b/client/main.cpp
index 73397fe..41a83a8 100644
--- a/client/main.cpp
+++ b/client/main.cpp
@@ -133,10 +133,6 @@ int adb_server_main(int is_daemon, const std::string& socket_spec, const char* o
 
     init_reconnect_handler();
 
-    if (mdns::is_enabled()) {
-        init_mdns_transport_discovery();
-    }
-
     if (!getenv("ADB_USB") || strcmp(getenv("ADB_USB"), "0") != 0) {
         if (is_libusb_enabled()) {
             libusb::usb_init();
-- 
